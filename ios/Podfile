# Standard Flutter Podfile for VISTA-APP
platform :ios, '15.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  
  # Try environment variable first (best for CI)
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']

  # Fallback to Generated.xcconfig
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end
  
  # Final fallback
  '/Users/runner/hostedtoolcache/flutter/stable/macos-latest/packages/flutter_tools' # This is just a guess, better to fail
end

f_root = flutter_root

# The standard Flutter build uses xcode_backend.rb to setup the build environment
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'xcode_backend.rb'), f_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.expand_path(File.join('..', '..'), __FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force iOS 15.0 for all plugins (required by cloud_firestore)
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
